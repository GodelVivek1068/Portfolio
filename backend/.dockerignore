# Files to exclude from deployment to Google Cloud

# Dependencies
node_modules/
npm-debug.log
yarn-error.log

# Environment files (use Cloud Run environment variables instead)
.env
.env.local
.env.*.local
.env.production.local
.env.production.secrets.txt

# Development files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.iml

# Build outputs (will be created during build)
dist/
build/
*.tar.gz

# Git and version control
.git/
.gitignore
.gitkeep

# CI/CD
.github/
.gitlab-ci.yml

# Testing and coverage
coverage/
.nyc_output/

# Logs
logs/
*.log

# Docker files (already handled)
.dockerignore
docker-compose.yml
Dockerfile.dev

# Development tools
nodemon.json
.env.example

# Railway files (not needed for GCP)
railway.json
railway.toml
Procfile
deploy.sh
deploy.bat

# Vercel config (not needed for GCP)
vercel.json

# Documentation and guides (optional - remove if you want docs in prod)
*.md
GCP_README.md
DEPLOYMENT_GUIDE.md
COMMANDS_REFERENCE.md
